[
  {
    "label": "Uptime",
    "command": "awk '{d=int($1/86400); h=int(($1%86400)/3600); print d\"d \"h\"h\"}' /proc/uptime",
    "type": "text",
    "color": "#00b894",
    "suffix": ""
  },
  {
    "label": "Temp",
    "command": "cat /sys/class/thermal/thermal_zone0/temp 2>/dev/null | awk '{print int($1/1000)}' || echo 0",
    "type": "text",
    "color": "#ff7675",
    "suffix": "°C"
  },
  {
    "label": "Load",
    "command": "cat /proc/loadavg | awk '{print $1}'",
    "type": "text",
    "color": "#fdcb6e",
    "suffix": ""
  },
  {
    "label": "Users",
    "command": "who | grep -c pts",
    "type": "text",
    "color": "#0984e3",
    "suffix": ""
  },
  {
    "label": "Docker",
    "command": "docker ps -q 2>/dev/null | wc -l",
    "type": "text",
    "color": "#0db7ed",
    "suffix": " run"
  },
  {
    "label": "GPU",
    "command": "nvidia-smi --query-gpu=utilization.gpu --format=csv,noheader,nounits 2>/dev/null || echo 0",
    "type": "progress",
    "color": "#76b900",
    "maxValue": 100,
    "suffix": "%"
  },
  {
    "label": "SSH Sessions",
    "command": "ss -tnp | grep sshd | grep ESTAB | wc -l",
    "type": "text",
    "color": "#00ff00",
    "suffix": ""
  },
  {
    "label": "I/O Wait",
    "command": "grep '^cpu ' /proc/stat > /tmp/cpu1; sleep 1; grep '^cpu ' /proc/stat >> /tmp/cpu1; awk 'NR==1{io1=$6;t1=$2+$3+$4+$5+$6+$7} NR==2{printf "%.2f\n",($6-io1)*100/($2+$3+$4+$5+$6+$7-t1)}' /tmp/cpu1",
    "type": "text",
    "color": "#fdcb6e",
    "suffix": "%"
  },
    {
    "label": "Steal",
    "command": "awk '/^cpu /{print $9, $2+$3+$4+$5+$6+$7+$8+$9+$10}' /proc/stat > /tmp/c1; sleep 1; awk '/^cpu /{print $9, $2+$3+$4+$5+$6+$7+$8+$9+$10}' /proc/stat > /tmp/c2; awk 'NR==1{s1=$1;t1=$2} NR==2{printf "%.2f%%\n", ($1-s1)/($2-t1)*100}' /tmp/c1 /tmp/c2",
    "type": "text",
    "color": "#dd27f5",
    "suffix": ""
  },
  {
    "label": "Failed Units",
    "command": "systemctl --failed --no-legend | wc -l",
    "type": "text",
    "color": "#ff7675",
    "suffix": ""
  }
]
